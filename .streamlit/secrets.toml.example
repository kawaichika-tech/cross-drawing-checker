# このファイルはサンプルです。
# 実際の secrets.toml はGitHubにアップしないでください（.gitignore で除外済み）。
#
# Streamlit Cloud での設定方法:
#   アプリのダッシュボード → Settings → Secrets に以下を貼り付ける
#
# [使い方]
# このファイルをコピーして .streamlit/secrets.toml という名前で保存し、
# ANTHROPIC_API_KEY に実際のAPIキーを入力してください。

ANTHROPIC_API_KEY = "sk-ant-api03-ここにAPIキーを貼り付ける"
